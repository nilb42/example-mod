{
  "geode": "3.3.0",
  "version": "v1.0.0",
  "id": "твойник.smooth_spam",
  "name": "Smooth Spam",
  "developer": "Твой Ник",
  "description": "Take your wave gameplay to the next level. Press '[' in-game to toggle the assistant ON/OFF instantly. Features customizable lock strength, Max CPS limiter, visual debug lines, and a soft stabilizer for accurate ship straightfly.",
  "early-load": false,
  "dependencies": [
    {
      "id": "geode.node-ids",
      "version": "v1.4.0"
    }
  ],
  "settings": {
    "enable-wave": {
      "name": "Enable Wave Assist",
      "description": "Включает логику выравнивания для волны.",
      "type": "bool",
      "default": true
    },
    "enable-ship": {
      "name": "Accurate Straightfly",
      "description": "Мягкий стабилизатор стрейтфлая для корабля.",
      "type": "bool",
      "default": true
    },
    "lock-strength": {
      "name": "Lock Strength (Wave)",
      "description": "Насколько сильно мод примагничивает вейв.",
      "type": "float",
      "default": 0.5,
      "min": 0.1,
      "max": 1.0,
      "control": "slider"
    },
    "max-cps": {
      "name": "Max CPS (Wave)",
      "description": "Максимальный CPS на волне.",
      "type": "int",
      "default": 15,
      "min": 8,
      "max": 30,
      "control": "slider"
    },
    "show-lines": {
      "name": "Show Lines",
      "description": "Показывает зеленую линию (дебаг).",
      "type": "bool",
      "default": false
    }
  }
}
